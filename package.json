    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.6",
    "prettier": "^3.9.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.9"
