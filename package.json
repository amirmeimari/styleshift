{
  "name": "styleshift",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && node scripts/build-extension.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
